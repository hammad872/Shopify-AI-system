# ============ Required ============

# Database (Phase 2)
# Atlas: Network Access → Add IP → 0.0.0.0/0 (allow from anywhere) for local dev.
MONGODB_URI="mongodb+srv://USER:PASS@cluster.mongodb.net/storepilot?retryWrites=true&w=majority"
# Optional: paste Atlas "Standard connection string" here if SRV DNS is flaky on your network
MONGODB_URI_STANDARD=""

# Auth (Phase 3) — generate secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Token encryption (Phase 4) — 32-byte key as 64 hex chars: openssl rand -hex 32
ENCRYPTION_KEY=""

# AI (Phase 6) — set at least one
GROQ_API_KEY=""
OPENAI_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
OPENAI_MODEL="gpt-4o-mini"

# ============ Shopify — one-click connect (recommended) ============
# Create ONE app in your free Shopify Partner account (partners.shopify.com).
# These identify YOUR app, not any store. With them set, merchants get the
# one-click "Connect with Shopify" flow. Leave blank to fall back to the
# manual access-token paste on the Stores page.
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_SCOPES="read_products,write_products,read_inventory,write_inventory"
SHOPIFY_APP_URL="http://localhost:3000"

